// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  STUDENT
  ADMIN
}

enum Category {
  STUDENT
  AFFILIATE
  STAFF
  INSTRUCTOR
  MANAGER
  ADMIN
  SUPER_ADMIN
}

model User {
  id                String             @id @default(cuid())
  name              String // derived "First Middle Last" — kept for all existing display code (Avatar, certificates, emails, etc.)
  firstName         String             @default("")
  middleName        String?
  lastName          String             @default("")
  gender            String? // "male" | "female" | "prefer_not_to_say" | "other"
  hearAboutUs       String? // e.g. "social_media" | "friend_referral" | "search_engine" | "advertisement" | "other"
  email             String             @unique
  passwordHash      String
  role              Role               @default(STUDENT)
  category          Category           @default(STUDENT)
  certificateName   String?
  country           String?
  createdAt         DateTime           @default(now())
  emailVerified     Boolean            @default(true) // default true so existing rows aren't locked out; signup explicitly sets false
  verificationCode        String?
  verificationCodeExpires DateTime?
  lessonCompletions LessonCompletion[]
  gamification      Gamification?
  badges            Badge[]
  certificates      Certificate[]
  comments          DiscussionComment[]
  attempts          ExamAttempt[]
  coachBookings     CoachBooking[]
  enrollments       Enrollment[]
  payments          Payment[]
  goals             Goal[]
  notifications     Notification[]
  instructedCourses Course[]           @relation("CourseInstructor")
  instructedCohorts Cohort[]           @relation("CohortInstructor")
  applications      Application[]
  reviewedApplications Application[]   @relation("ApplicationReviewer")
  attendances       Attendance[]       @relation("AttendanceStudent")
  markedAttendances Attendance[]       @relation("AttendanceMarkedBy")
  createdAssignments Assignment[]      @relation("AssignmentCreator")
  assignmentSubmissions AssignmentSubmission[] @relation("SubmissionStudent")
  gradedSubmissions AssignmentSubmission[] @relation("SubmissionGrader")
  coachProfile      Coach?             @relation("CoachAccount")
  membershipSubscriptions MembershipSubscription[]
  resume            Resume?
  resetToken        String?
  resetTokenExpires DateTime?
}

model LessonCompletion {
  id          String   @id @default(cuid())
  userId      String
  courseSlug  String
  lessonId    String
  completedAt DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseSlug, lessonId])
}

model Gamification {
  userId     String   @id
  xp         Int      @default(0)
  streak     Int      @default(0)
  lastActive String
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Badge {
  id         String   @id @default(cuid())
  userId     String
  badgeId    String
  unlockedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
}

enum LessonType {
  VIDEO
  READING
  QUIZ
}

model Course {
  slug             String       @id
  title            String
  subtitle         String
  category         String
  instructor       String
  instructorUserId String?      // real account assignment, for instructor-scoped admin views; `instructor` above stays the free-text display name
  instructorUser   User?        @relation("CourseInstructor", fields: [instructorUserId], references: [id], onDelete: SetNull)
  cover            String
  description      String       @db.Text
  price            Float        @default(0)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  modules          Module[]
  enrollments      Enrollment[]
  goals            Goal[]
  cohorts          Cohort[]
  applications     Application[]
}

enum CohortStatus {
  UPCOMING
  ENROLLMENT_OPEN
  ONGOING
  COMPLETED
  ARCHIVED
}

/** A specific timed running of a program (Course). Enrollment.cohortId is nullable so instant/self-paced enrollments (no cohort picked) keep working alongside cohort-based ones. */
model Cohort {
  id                 String       @id @default(cuid())
  courseSlug         String
  course             Course       @relation(fields: [courseSlug], references: [slug], onDelete: Cascade)
  name               String // e.g. "January 2026 Cohort"
  startDate          DateTime
  endDate            DateTime
  enrollmentDeadline DateTime?
  orientationDate    DateTime?
  capacity           Int? // null = unlimited
  timezone           String       @default("UTC")
  schedule           String       @default("") // free text, e.g. "Mon/Wed/Fri 6-8pm"
  status             CohortStatus @default(UPCOMING)
  instructorUserId   String?
  instructorUser     User?        @relation("CohortInstructor", fields: [instructorUserId], references: [id], onDelete: SetNull)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  enrollments        Enrollment[]
  applications       Application[]
  attendances        Attendance[]
  assignments        Assignment[]

  @@index([courseSlug])
}

enum ApplicationStatus {
  SUBMITTED
  UNDER_REVIEW
  ADMITTED
  REJECTED
  WAITLISTED
}

/**
 * Applies only to programs that have cohorts — a program with none keeps
 * the existing instant self-paced enroll/buy flow untouched. One row per
 * student per program: admitting/rejecting updates this row rather than
 * creating a new one, so there's no separate "re-apply" flow yet.
 */
model Application {
  id           String            @id @default(cuid())
  userId       String
  courseSlug   String
  cohortId     String? // the specific cohort applied to; null = "next available"
  status       ApplicationStatus @default(SUBMITTED)
  motivation   String?           @db.Text
  experience   String?           @db.Text
  reviewNote   String?           @db.Text
  reviewedById String?
  reviewedAt   DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  course       Course            @relation(fields: [courseSlug], references: [slug], onDelete: Cascade)
  cohort       Cohort?           @relation(fields: [cohortId], references: [id], onDelete: SetNull)
  reviewedBy   User?             @relation("ApplicationReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@unique([userId, courseSlug])
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
}

/**
 * One row per student per class session. Sessions aren't a separate model —
 * Cohort.schedule is free text, not structured dates — so a session is
 * implicitly "whatever date an instructor took attendance for," created
 * on demand rather than pre-scheduled.
 */
model Attendance {
  id         String           @id @default(cuid())
  cohortId   String
  cohort     Cohort           @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  userId     String
  user       User             @relation("AttendanceStudent", fields: [userId], references: [id], onDelete: Cascade)
  date       DateTime         @db.Date
  status     AttendanceStatus
  note       String?
  markedById String?
  markedBy   User?            @relation("AttendanceMarkedBy", fields: [markedById], references: [id], onDelete: SetNull)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@unique([cohortId, userId, date])
  @@index([cohortId, date])
}

enum SubmissionType {
  FILE
  GITHUB
  PORTFOLIO
  DRIVE
  VIDEO
}

enum SubmissionStatus {
  SUBMITTED
  UNDER_REVIEW
  GRADED
  RESUBMISSION_REQUESTED
}

/** Belongs to a Cohort (not the Course content shell) since due dates are inherently cohort-specific — two cohorts running the same program have their own timelines. */
model Assignment {
  id          String                 @id @default(cuid())
  cohortId    String
  cohort      Cohort                 @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  title       String
  description String                 @db.Text
  dueDate     DateTime?
  maxScore    Int                    @default(100)
  createdById String?
  createdBy   User?                  @relation("AssignmentCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  submissions AssignmentSubmission[]

  @@index([cohortId])
}

/**
 * One row per student per assignment — resubmitting updates this row
 * (and resets status to SUBMITTED) rather than creating a new one, same
 * "one row, status transitions" pattern as Application.
 */
model AssignmentSubmission {
  id           String           @id @default(cuid())
  assignmentId String
  assignment   Assignment       @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  userId       String
  user         User             @relation("SubmissionStudent", fields: [userId], references: [id], onDelete: Cascade)
  type         SubmissionType
  url          String // uploaded-file path for FILE, the link itself for GITHUB/PORTFOLIO/DRIVE/VIDEO
  note         String?          @db.Text
  status       SubmissionStatus @default(SUBMITTED)
  grade        Int?
  feedback     String?          @db.Text
  gradedById   String?
  gradedBy     User?            @relation("SubmissionGrader", fields: [gradedById], references: [id], onDelete: SetNull)
  gradedAt     DateTime?
  submittedAt  DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@unique([assignmentId, userId])
}

/** Canonical list of course category names, managed from /admin/categories. Course.category stores the name as a plain string (not a relation) to match this app's existing free-text pattern, kept in sync on rename. */
model CourseCategory {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())
}

model Module {
  id         String   @id @default(cuid())
  moduleId   String   // e.g. "m1"
  title      String
  courseSlug String
  course     Course   @relation(fields: [courseSlug], references: [slug], onDelete: Cascade)
  lessons    Lesson[]
}

model Lesson {
  id        String         @id @default(cuid())
  lessonId  String         // e.g. "l1"
  title     String
  type      LessonType
  duration  Int
  content   String         @db.Text // JSON string of string[]
  videoUrl  String         @default("") // YouTube/Vimeo embed URL or direct .mp4 link
  moduleId  String
  module    Module         @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  questions QuizQuestion[]
  comments  DiscussionComment[]
}

model QuizQuestion {
  id          String   @id @default(cuid())
  questionId  String   // e.g. "q1"
  prompt      String   @db.Text
  options     String   @db.Text // JSON string of options
  correctId   String
  explanation String   @db.Text
  lessonId    String
  lesson      Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
}

model PracticeExam {
  categorySlug    String         @id
  categoryName    String
  durationMinutes Int
  questions       ExamQuestion[]
}

model ExamQuestion {
  id          String       @id @default(cuid())
  questionId  String       // e.g. "ct1"
  prompt      String       @db.Text
  options     String       @db.Text // JSON string of options
  correctId   String
  explanation String       @db.Text
  examSlug    String
  exam        PracticeExam @relation(fields: [examSlug], references: [categorySlug], onDelete: Cascade)
}

model GeneralSettings {
  id              Int      @id @default(1)
  siteName        String   @default("TekSkillUp")
  supportEmail    String   @default("")
  timezone        String   @default("UTC")
  maintenanceMode Boolean  @default(false)
  updatedAt       DateTime @updatedAt
}

/** Singleton: the currency every course price is denominated in. */
model PaymentSettings {
  id        Int      @id @default(1)
  currency  String   @default("USD")
  updatedAt DateTime @updatedAt
}

/** Admin-set conversion rate for one non-base currency, for display-only price estimates. */
model CurrencyRate {
  code      String   @id // ISO code, e.g. "USD"
  label     String   // e.g. "US Dollar"
  rate      Float    // 1 unit of this currency = `rate` units of the base (PaymentSettings.currency)
  updatedAt DateTime @updatedAt
}

/** One row per payment processor (id = "fincra" | "paystack"), independently toggleable. */
model PaymentGateway {
  id            String   @id // "fincra" | "paystack"
  enabled       Boolean  @default(false)
  mode          String   @default("test") // "test" | "live" — which key pair below is active
  testPublicKey String   @default("")
  testSecretKey String   @default("") // never returned raw to client
  livePublicKey String   @default("")
  liveSecretKey String   @default("") // never returned raw to client
  webhookSecret String   @default("") // never returned raw to client; Fincra-only, Paystack verifies with its secret key instead
  encryptionKey String   @default("") // never returned raw to client; Fincra-only, encrypts card details client-side
  businessId    String   @default("") // Fincra-only, not secret; required by its merchant-reference verify endpoint
  currencies    String   @default("") // comma-separated ISO codes this gateway can charge; empty = accept the order currency unconditionally
  updatedAt     DateTime @updatedAt
}

model SmtpSettings {
  id        Int      @id @default(1)
  host      String   @default("")
  port      Int      @default(587)
  username  String   @default("")
  password  String   @default("") // never returned raw to client
  fromName  String   @default("")
  fromEmail String   @default("")
  secure    Boolean  @default(true)
  updatedAt DateTime @updatedAt
}

model EmailTemplate {
  key         String   @id // admin-chosen slug, e.g. "welcome-email"
  name        String
  description String   @default("")
  subject     String
  body        String   @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model BrandingSettings {
  id            Int      @id @default(1)
  headerLogo    String? // public path under /uploads/branding, e.g. "/uploads/branding/header-<uuid>.png"
  footerLogo    String?
  dashboardLogo String?
  invoiceLogo   String?
  faviconLogo   String?
  updatedAt     DateTime @updatedAt
}

model Certificate {
  id          String   @id // e.g. "TSU-4F9A2C" (credentialId)
  userId      String
  courseSlug  String
  studentName String
  courseTitle String
  dateIssued  DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseSlug])
}

model DiscussionComment {
  id        String              @id @default(cuid())
  lessonId  String
  userId    String
  content   String              @db.Text
  createdAt DateTime            @default(now())
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson    Lesson              @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  parentId  String?
  parent    DiscussionComment?  @relation("Replies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   DiscussionComment[] @relation("Replies")
}

model ExamAttempt {
  id               String   @id @default(cuid())
  userId           String
  examSlug         String   // categorySlug
  scorePercent     Int
  timeSpentSeconds Int
  completedAt      DateTime @default(now())
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Coach {
  id           String               @id @default(cuid())
  name         String
  role         String
  focus        String
  bio          String               @db.Text
  accent       String               @default("navy") // navy | orange | green | slate — see Avatar component
  bookable     Boolean              @default(true)
  userId       String?              @unique // linked login for the coach portal (/coach) — nullable so legacy/unlinked coach records still work
  user         User?                @relation("CoachAccount", fields: [userId], references: [id], onDelete: SetNull)
  availability CoachAvailability[]
  bookings     CoachBooking[]
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
}

/** A coach's own weekly recurring availability, self-managed from the coach portal — replaces the old shared static template. */
model CoachAvailability {
  id       String @id @default(cuid())
  coachId  String
  weekday  Int // follows Date.getDay() (0=Sun..6=Sat)
  time     String // "HH:MM", 24-hour
  coach    Coach  @relation(fields: [coachId], references: [id], onDelete: Cascade)

  @@unique([coachId, weekday, time])
}

model CoachBooking {
  id        String   @id @default(cuid())
  userId    String
  coachId   String? // nullable so a coach's booking history survives the Coach record being deleted
  coachName String // snapshot of Coach.name at booking time — intentionally not a foreign key so a coach's history survives edits/removal
  sessionAt DateTime // exact session start time, projected from the coach's own CoachAvailability
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  coach     Coach?   @relation(fields: [coachId], references: [id], onDelete: SetNull)

  @@unique([coachName, sessionAt])
}

model Enrollment {
  id         String   @id @default(cuid())
  userId     String
  courseSlug String
  cohortId   String? // nullable — self-paced/instant enrollments have no cohort
  enrolledAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course     Course   @relation(fields: [courseSlug], references: [slug], onDelete: Cascade)
  cohort     Cohort?  @relation(fields: [cohortId], references: [id], onDelete: SetNull)

  @@unique([userId, courseSlug])
}

/** A student's self-set target completion date for one enrolled course. */
model Goal {
  id         String   @id @default(cuid())
  userId     String
  courseSlug String
  targetDate DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course     Course   @relation(fields: [courseSlug], references: [slug], onDelete: Cascade)

  @@unique([userId, courseSlug])
}

/** In-app notification, e.g. "enrolled in a course", "certificate issued". */
model Notification {
  id        String   @id @default(cuid())
  userId    String
  kind      String   @default("info") // "enrollment" | "certificate" | "coach_booking"
  title     String
  href      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
}

model Payment {
  id          String   @id @default(cuid())
  userId      String
  courseSlug  String
  amount      Float
  currency    String
  provider    String   @default("fincra")
  providerRef String   // Fincra transaction reference
  status      String   @default("pending") // pending | success | failed
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/**
 * One of the 5 admin-tier roles (super_admin/admin/manager/staff/instructor).
 * Its `key` matches the corresponding admin-tier Category value (lowercased),
 * so a user's existing Category is the single source of truth for which
 * AdminRole applies — no separate role-assignment field needed on User.
 */
model AdminRole {
  id          String           @id @default(cuid())
  key         String           @unique
  name        String
  description String           @default("")
  isSystem    Boolean          @default(false) // Super Admin — always all permissions, not editable
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  permissions RolePermission[]
}

model RolePermission {
  id     String    @id @default(cuid())
  roleId String
  role   AdminRole @relation(fields: [roleId], references: [id], onDelete: Cascade)
  key    String    // e.g. "courses:edit" — see src/lib/permissions.ts for the full set

  @@unique([roleId, key])
}

/** Admin-managed subscription tier: a discount % + perks students get on course purchases. */
model MembershipPlan {
  id            String                   @id @default(cuid())
  name          String
  price         Float
  discountPct   Int                      @default(0)
  perks         String                   @db.Text // JSON string array of perk description lines
  active        Boolean                  @default(true)
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt
  subscriptions MembershipSubscription[]
}

/**
 * A student's purchase of a membership plan. Reuses the same one-time
 * checkout mechanics as course payments (no gateway subscription/recurring
 * API integration) — "active" means currentPeriodEnd is in the future;
 * renewing means purchasing again before/after it lapses.
 */
model MembershipSubscription {
  id               String          @id @default(cuid())
  userId           String
  planId           String
  status           String          @default("pending") // pending | active | expired | failed
  provider         String?
  providerRef      String?
  amount           Float?
  currency         String?
  currentPeriodEnd DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan             MembershipPlan  @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([userId, planId])
}

/**
 * A student's CV/resume, built inside the platform. Verified certificates are
 * intentionally NOT stored here — the builder pulls them live from the real
 * Certificate table so the CV can never show a stale or fabricated credential.
 */
model Resume {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  headline     String   @default("")
  summary      String   @default("") @db.Text
  phone        String   @default("")
  location     String   @default("")
  linkedinUrl  String   @default("")
  githubUrl    String   @default("")
  portfolioUrl String   @default("")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  education  ResumeEducation[]
  experience ResumeExperience[]
  skills     ResumeSkill[]
  projects   ResumeProject[]
}

model ResumeEducation {
  id           String    @id @default(cuid())
  resumeId     String
  resume       Resume    @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  school       String
  degree       String    @default("")
  fieldOfStudy String    @default("")
  startDate    DateTime?
  endDate      DateTime?
  current      Boolean   @default(false)
  description  String    @default("") @db.Text
  sortOrder    Int       @default(0)

  @@index([resumeId])
}

model ResumeExperience {
  id          String    @id @default(cuid())
  resumeId    String
  resume      Resume    @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  company     String
  role        String
  location    String    @default("")
  startDate   DateTime?
  endDate     DateTime?
  current     Boolean   @default(false)
  description String    @default("") @db.Text
  sortOrder   Int       @default(0)

  @@index([resumeId])
}

model ResumeSkill {
  id        String @id @default(cuid())
  resumeId  String
  resume    Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  name      String
  sortOrder Int    @default(0)

  @@index([resumeId])
}

model ResumeProject {
  id          String @id @default(cuid())
  resumeId    String
  resume      Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  title       String
  url         String @default("")
  description String @default("") @db.Text
  sortOrder   Int    @default(0)

  @@index([resumeId])
}
